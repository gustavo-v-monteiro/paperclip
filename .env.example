# Database
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip

# Server
PORT=3100
HOST=0.0.0.0
SERVE_UI=true  # set to false for local API-only dev
NODE_ENV=production

# Paperclip
PAPERCLIP_HOME=/paperclip
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_CONFIG=/paperclip/instances/default/config.json
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
PAPERCLIP_PUBLIC_URL=https://your-app.up.railway.app

# Auth (required — generate a strong random secret)
BETTER_AUTH_SECRET=replace-me-with-a-strong-random-secret
